{
  "name": "pdf-accessibility-app",
  "version": "1.0.1",
  "description": "Web application for PDF accessibility evaluation and automatic remediation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "prepare": "husky install",
    "release": "standard-version",
    "changelog": "standard-version --dry-run"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "commitizen": "^4.0.0",
    "cz-git": "^1.0.0",
    "standard-version": "^9.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "pdf",
    "accessibility",
    "wcag",
    "remediation",
    "a11y"
  ],
  "author": "PDF Accessibility Tool",
  "license": "MIT"
}
